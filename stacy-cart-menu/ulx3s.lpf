IOBUF PORT "cart_d_out[10]" PULLMODE=DOWN IO_TYPE=LVCMOS33 DRIVE=4;
IOBUF PORT "cart_d_out[11]" PULLMODE=DOWN IO_TYPE=LVCMOS33 DRIVE=4;
IOBUF PORT "cart_d_out[12]" PULLMODE=DOWN IO_TYPE=LVCMOS33 DRIVE=4;
IOBUF PORT "cart_d_out[13]" PULLMODE=DOWN IO_TYPE=LVCMOS33 DRIVE=4;
IOBUF PORT "cart_d_out[14]" PULLMODE=DOWN IO_TYPE=LVCMOS33 DRIVE=4;
IOBUF PORT "cart_d_out[15]" PULLMODE=DOWN IO_TYPE=LVCMOS33 DRIVE=4;

IOBUF PORT "dir4" PULLMODE=NONE IO_TYPE=LVCMOS33 DRIVE=4;
IOBUF PORT "oe4"  PULLMODE=NONE IO_TYPE=LVCMOS33 DRIVE=4;
IOBUF PORT "dir5" PULLMODE=NONE IO_TYPE=LVCMOS33 DRIVE=4;
IOBUF PORT "oe5"  PULLMODE=NONE IO_TYPE=LVCMOS33 DRIVE=4;
IOBUF PORT "test_io" PULLMODE=DOWN IO_TYPE=LVCMOS33 DRIVE=4;

IOBUF PORT "pwr_ctl"    PULLMODE=DOWN IO_TYPE=LVCMOS33 DRIVE=4;
IOBUF PORT "pwr_stat_n" PULLMODE=UP   IO_TYPE=LVCMOS33;
