IOBUF PORT "cart_a[8]" PULLMODE=DOWN IO_TYPE=LVCMOS33;
IOBUF PORT "cart_a[9]" PULLMODE=DOWN IO_TYPE=LVCMOS33;
IOBUF PORT "cart_a[10]" PULLMODE=DOWN IO_TYPE=LVCMOS33;
IOBUF PORT "cart_a[11]" PULLMODE=DOWN IO_TYPE=LVCMOS33;
IOBUF PORT "cart_a[12]" PULLMODE=DOWN IO_TYPE=LVCMOS33;
IOBUF PORT "cart_a[13]" PULLMODE=DOWN IO_TYPE=LVCMOS33;
IOBUF PORT "cart_a[14]" PULLMODE=DOWN IO_TYPE=LVCMOS33;
IOBUF PORT "cart_a[15]" PULLMODE=DOWN IO_TYPE=LVCMOS33;

IOBUF PORT "rom3_n" PULLMODE=DOWN IO_TYPE=LVCMOS33;
IOBUF PORT "rom4_n" PULLMODE=DOWN IO_TYPE=LVCMOS33;
IOBUF PORT "uds_n" PULLMODE=DOWN IO_TYPE=LVCMOS33;
IOBUF PORT "lds_n" PULLMODE=DOWN IO_TYPE=LVCMOS33;

IOBUF PORT "cart_d_out[0]" PULLMODE=DOWN IO_TYPE=LVCMOS33 DRIVE=4;
